{
  "name": "edenwright-monorepo",
  "version": "0.1.0-beta",
  "private": true,
  "type": "module",
  "description": "Edenwright — an open-source desktop studio for every kind of story.",
  "license": "MIT",
  "packageManager": "pnpm@9.15.9",
  "engines": {
    "node": ">=22",
    "pnpm": ">=9"
  },
  "scripts": {
    "dev": "pnpm --filter edenwright dev",
    "build": "pnpm -r run build",
    "test": "pnpm -r run --if-present test",
    "test:e2e": "pnpm --filter edenwright test:e2e",
    "test:registry": "node registry/validate.mjs",
    "lint": "eslint . && prettier --check .",
    "format": "prettier --write . && eslint . --fix",
    "typecheck": "pnpm -r run --if-present typecheck",
    "package": "pnpm --filter edenwright package"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "eslint": "^9.39.2",
    "eslint-plugin-react-hooks": "^5.2.0",
    "globals": "^17.7.0",
    "prettier": "^3.8.1",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.57.2"
  }
}
