{
  "name": "@edenwright/ui",
  "version": "0.1.0-beta",
  "description": "Edenwright shared UI: design tokens (SPEC §3.1), base chrome components, icon wrappers. No hardcoded hex — tokens only.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./styles/tokens.css": "./src/styles/tokens.css",
    "./styles/global.css": "./src/styles/global.css",
    "./assets/bloom-icon.svg": "./src/assets/bloom-icon.svg"
  },
  "files": [
    "dist",
    "src/styles",
    "src/assets"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json && node scripts/copy-css.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "lucide-react": "^1.25.0"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "devDependencies": {
    "@types/react": "^18.3.31",
    "@types/react-dom": "^18.3.7",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "typescript": "~5.9.3"
  }
}
