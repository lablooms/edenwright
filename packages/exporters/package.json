{
  "name": "@edenwright/exporters",
  "version": "0.1.0-beta",
  "description": "Export backends for Edenwright engines (SPEC §10): docx, EPUB, print-clean HTML, Fountain, FDX, Twee, Ren'Py. Pure TypeScript — portable like core.",
  "license": "MIT",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./golden": "./src/golden.ts"
  },
  "scripts": {
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@edenwright/core": "workspace:*",
    "docx": "^9.5.1",
    "jszip": "^3.10.1"
  },
  "devDependencies": {
    "typescript": "~5.9.3",
    "vitest": "^4.1.10"
  }
}
