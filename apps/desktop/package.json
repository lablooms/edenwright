{
  "name": "edenwright",
  "productName": "Edenwright",
  "version": "0.1.0-beta",
  "description": "An open-source desktop studio for every kind of story.",
  "license": "MIT",
  "author": "Lablooms Studio",
  "homepage": "https://github.com/lablooms/edenwright",
  "desktopName": "Edenwright",
  "private": true,
  "type": "module",
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "node scripts/ensure-sqlite.mjs electron && node scripts/generate-icons.mjs && electron-vite dev",
    "build": "node scripts/generate-icons.mjs && electron-vite build",
    "preview": "electron-vite preview",
    "icons": "node scripts/generate-icons.mjs",
    "package": "node scripts/ensure-sqlite.mjs electron && pnpm run build && electron-builder",
    "test": "node scripts/ensure-sqlite.mjs node && vitest run",
    "test:e2e": "node scripts/ensure-sqlite.mjs electron && playwright test",
    "typecheck": "tsc --noEmit -p tsconfig.node.json && tsc --noEmit -p tsconfig.web.json"
  },
  "dependencies": {
    "@codemirror/autocomplete": "^6.20.3",
    "@codemirror/commands": "^6.10.4",
    "@codemirror/lang-markdown": "^6.5.1",
    "@codemirror/language": "^6.12.4",
    "@codemirror/search": "^6.7.1",
    "@codemirror/state": "^6.5.2",
    "@codemirror/view": "^6.43.6",
    "@edenwright/core": "workspace:*",
    "@edenwright/exporters": "workspace:*",
    "@edenwright/plugin-api": "workspace:*",
    "@edenwright/ui": "workspace:*",
    "@fontsource/courier-prime": "^5.3.0",
    "@fontsource/jetbrains-mono": "^5.3.0",
    "@fontsource/literata": "^5.3.0",
    "@fontsource/space-grotesk": "^5.3.0",
    "@lezer/highlight": "^1.2.3",
    "@lezer/markdown": "^1.7.2",
    "better-sqlite3": "^12.11.1",
    "chokidar": "^5.0.0",
    "codemirror": "^6.0.2",
    "jszip": "^3.10.1",
    "lucide-react": "^1.25.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.2.0",
    "@playwright/test": "^1.61.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^24.13.3",
    "@types/react": "^18.3.31",
    "@types/react-dom": "^18.3.7",
    "@vitejs/plugin-react": "^5.2.0",
    "electron": "^42.7.0",
    "electron-builder": "^26.15.3",
    "electron-vite": "^5.0.0",
    "png2icons": "^2.0.1",
    "prebuild-install": "^7.1.3",
    "sharp": "^0.35.3",
    "typescript": "~5.9.3",
    "vite": "^7.0.0",
    "vitest": "^4.1.10"
  }
}
